# Banking CRM Agent — Environment Variables
# Copy this file to backend/.env and fill in your values

# ── LLM Provider (Groq recommended — free tier at console.groq.com) ──────────
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# ── Alternative: Google Gemini ────────────────────────────────────────────────
# GOOGLE_API_KEY=your_google_api_key_here
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash

# ── Alternative: Anthropic Claude ────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001

# ── Database (default: SQLite — no setup needed) ─────────────────────────────
DATABASE_URL=sqlite:///./banking_crm.db

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Frontend (Vite env vars) ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
